# Optional overrides. docker compose works with no .env at all — these are the
# defaults baked into docker-compose.yml. Copy to .env to customise.

# --- Postgres connection (used by seed + streamer) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret

# --- Seed volume ---
SEED_USERS=1000
SEED_ASSISTANTS=50
SEED_CONVERSATIONS=5000
SEED_MESSAGES=100000
SEED_DAYS=90
SEED_FEEDBACK_RATE=0.15

# --- Live streamer ---
STREAM_INTERVAL=2
STREAM_BATCH_MIN=1
STREAM_BATCH_MAX=10
